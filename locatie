<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kies locatie — Avondevaluatie</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #ffffff; --bg2: #f5f5f3; --bg3: #efefed;
      --text: #1a1a1a; --text2: #666660; --text3: #999993;
      --border: rgba(0,0,0,0.12); --border2: rgba(0,0,0,0.22);
      --radius: 8px; --radius-lg: 12px;
      --green-bg: #eaf3de; --green-text: #3b6d11;
      --blue-bg: #e6f1fb; --blue-text: #0c447c;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1e1e1c; --bg2: #272725; --bg3: #2f2f2d;
        --text: #f0f0ee; --text2: #aaaaaa; --text3: #666660;
        --border: rgba(255,255,255,0.1); --border2: rgba(255,255,255,0.2);
        --green-bg: #173404; --green-text: #c0dd97;
        --blue-bg: #042c53; --blue-text: #b5d4f4;
      }
    }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg3); color: var(--text); min-height: 100vh; padding: 1.5rem 1rem 3rem; }
    .container { max-width: 600px; margin: 0 auto; }
    .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; }
    .header-left { display: flex; flex-direction: column; gap: 4px; }
    h1 { font-size: 20px; font-weight: 500; }
    .welkom { font-size: 13px; color: var(--text2); }
    .btn { padding: 7px 13px; font-size: 13px; border: 0.5px solid var(--border2); border-radius: var(--radius); background: var(--bg); color: var(--text2); cursor: pointer; display: inline-flex; align-items: center; gap: 5px; font-family: inherit; transition: background 0.15s; text-decoration: none; }
    .btn:hover { background: var(--bg2); }
    .header-right { display: flex; gap: 8px; }

    .sectie-label { font-size: 12px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500; margin-bottom: 10px; }

    .locatie-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 1.5rem; }
    @media (max-width: 480px) { .locatie-grid { grid-template-columns: 1fr; } }

    .locatie-card {
      background: var(--bg); border: 0.5px solid var(--border);
      border-radius: var(--radius-lg); padding: 16px;
      cursor: pointer; transition: all 0.15s;
      display: flex; align-items: center; gap: 12px;
      text-decoration: none; color: var(--text);
    }
    .locatie-card:hover { border-color: var(--border2); background: var(--bg2); transform: translateY(-1px); box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .locatie-icon { width: 36px; height: 36px; border-radius: var(--radius); background: var(--bg2); display: flex; align-items: center; justify-content: center; font-size: 16px; color: var(--text2); flex-shrink: 0; }
    .locatie-naam { font-size: 14px; font-weight: 500; }
    .locatie-sub { font-size: 11px; color: var(--text3); margin-top: 2px; }

    .dashboard-link { background: var(--bg); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 14px 16px; display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--text); transition: all 0.15s; }
    .dashboard-link:hover { background: var(--bg2); border-color: var(--border2); }
    .dashboard-link i { font-size: 20px; color: var(--text2); }
    .dashboard-link-text { font-size: 14px; font-weight: 500; }
    .dashboard-link-sub { font-size: 12px; color: var(--text3); }

    .loading { text-align: center; padding: 3rem; color: var(--text3); }
    .spinner { width: 20px; height: 20px; border: 2px solid var(--border2); border-top-color: var(--text); border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 12px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes fadein { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
    .locatie-card, .dashboard-link { animation: fadein 0.2s ease; }
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <div class="header-left">
      <h1>Avondevaluatie</h1>
      <span class="welkom" id="welkomTekst">Welkom</span>
    </div>
    <div class="header-right">
      <button class="btn" onclick="uitloggen()"><i class="ti ti-logout"></i> Uitloggen</button>
    </div>
  </div>

  <div id="inhoud">
    <div class="loading"><div class="spinner"></div>Laden...</div>
  </div>
</div>

<script>
const _locUrl  = 'https://gobqaidvirtadgpduznd.supabase.co';
const _locAnon = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdvYnFhaWR2aXJ0YWRncGR1em5kIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEwOTI0OTgsImV4cCI6MjA5NjY2ODQ5OH0.1e3jxFsGKaylTJCIvqZEP-m-F_j1Az1L06et9DP2rYo';
var supabase = window.supabase.createClient(_locUrl, _locAnon);

const LOCATIE_ICONS = {
  'Café Van Buren': 'ti-coffee',
  'Club Rolluik': 'ti-music',
  'BAR 2': 'ti-glass',
  'De Drie Gezusters': 'ti-star',
  "Heidi's Skihut": 'ti-mountain',
  'De Kunstbar': 'ti-palette',
  'Club Novia': 'ti-diamond',
  'De Bieb': 'ti-books',
  'Stadsgarderobe 024': 'ti-hanger'
};

async function init() {
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) { window.location.href = '/auth.html'; return; }

  const { data: profiel } = await supabase
    .from('gebruikers')
    .select('naam, rol, goedgekeurd, gebruiker_locaties(locatie_id, is_hoofdlocatie)')
    .eq('id', session.user.id)
    .single();

  if (!profiel?.goedgekeurd) { window.location.href = '/auth.html'; return; }

  document.getElementById('welkomTekst').textContent = `Welkom, ${profiel.naam}`;

  // Admin en rayonmanager: alle locaties
  let locaties = [];
  if (profiel.rol === 'admin' || profiel.rol === 'rayonmanager') {
    const { data } = await supabase.from('locaties').select('*').eq('actief', true).order('naam');
    locaties = data || [];
  } else if (profiel.rol === 'kijker') {
    // Kijker: geen nieuwe evaluaties aanmaken, alleen dashboard
    renderKijker(profiel);
    return;
  } else {
    // Bedrijfsleider / shiftmanager: toegewezen locaties
    const locatieIds = (profiel.gebruiker_locaties || []).map(t => t.locatie_id);
    if (locatieIds.length > 0) {
      const { data } = await supabase.from('locaties').select('*').in('id', locatieIds).order('naam');
      locaties = data || [];
    }
  }

  renderLocaties(locaties, profiel);
}

function renderLocaties(locaties, profiel) {
  const kanDashboard = profiel.rol !== 'shiftmanager';

  let html = '';

  if (locaties.length > 0) {
    html += `<div class="sectie-label">Kies een locatie om een evaluatie te starten</div>`;
    html += `<div class="locatie-grid">`;
    html += locaties.map(loc => `
      <a class="locatie-card" href="/index.html?locatie=${encodeURIComponent(loc.naam)}&locatie_id=${loc.id}" >
        <div class="locatie-icon"><i class="ti ${LOCATIE_ICONS[loc.naam] || 'ti-building'}"></i></div>
        <div>
          <div class="locatie-naam">${escHtml(loc.naam)}</div>
          <div class="locatie-sub">Evaluatie starten</div>
        </div>
      </a>`).join('');
    html += `</div>`;
  } else {
    html += `<p style="font-size:13px;color:var(--text3);margin-bottom:1.5rem;">Je hebt nog geen locaties toegewezen gekregen. Neem contact op met een beheerder.</p>`;
  }

  html += `
    <div class="sectie-label" style="margin-top:0.5rem;">Overzicht</div>
    <a class="dashboard-link" href="/dashboard.html">
      <i class="ti ti-layout-dashboard"></i>
      <div>
        <div class="dashboard-link-text">Dashboard</div>
        <div class="dashboard-link-sub">Bekijk eerder gemaakte evaluaties</div>
      </div>
      <i class="ti ti-chevron-right" style="margin-left:auto;color:var(--text3);"></i>
    </a>`;

  document.getElementById('inhoud').innerHTML = html;
}

function renderKijker(profiel) {
  document.getElementById('inhoud').innerHTML = `
    <div class="sectie-label">Overzicht</div>
    <a class="dashboard-link" href="/dashboard.html">
      <i class="ti ti-layout-dashboard"></i>
      <div>
        <div class="dashboard-link-text">Dashboard</div>
        <div class="dashboard-link-sub">Bekijk evaluaties van jouw locaties</div>
      </div>
      <i class="ti ti-chevron-right" style="margin-left:auto;color:var(--text3);"></i>
    </a>`;
}

function escHtml(t) {
  return String(t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

async function uitloggen() {
  await supabase.auth.signOut();
  window.location.href = '/auth.html';
}

init();
</script>
</body>
</html>
